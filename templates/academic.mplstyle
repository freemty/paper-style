# Paper Style — Academic matplotlib style
# Usage: plt.style.use("academic.mplstyle")

font.family: serif
font.size: 10

axes.labelsize: 11
axes.titlesize: 12
axes.grid: True
axes.spines.top: False
axes.spines.right: False

grid.alpha: 0.15
grid.linestyle: --

legend.frameon: True
legend.framealpha: 0.9
legend.fontsize: 9

figure.dpi: 300
figure.facecolor: white

savefig.dpi: 300
savefig.bbox: tight
savefig.pad_inches: 0.1
